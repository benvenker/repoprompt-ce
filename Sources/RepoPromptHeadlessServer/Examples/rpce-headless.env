# Copy to /etc/rpce-headless/rpce-headless.env and adjust for the host.
#
# Deterministic tools do not require an oracle key. oracle_send and
# context-build --response-type question|plan do.

RPCE_ORACLE_BASE_URL=https://openrouter.ai/api/v1
RPCE_ORACLE_MODEL=openrouter/auto

# Prefer RPCE_ORACLE_API_KEY for this service. OPENROUTER_API_KEY is also
# accepted for local shell usage.
RPCE_ORACLE_API_KEY=

# Optional state/cache locations. systemd can also set these via StateDirectory
# and CacheDirectory if you prefer service-managed paths.
XDG_STATE_HOME=/var/lib/rpce-headless/state
XDG_CACHE_HOME=/var/cache/rpce-headless
