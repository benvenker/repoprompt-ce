[Unit]
Description=RepoPrompt CE headless discovery MCP socket server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=rpce
Group=rpce
EnvironmentFile=/etc/rpce-headless/rpce-headless.env
WorkingDirectory=/srv/repoprompt-ce
RuntimeDirectory=rpce-headless
RuntimeDirectoryMode=0700
StateDirectory=rpce-headless
CacheDirectory=rpce-headless
UMask=0077
ExecStart=/usr/local/bin/rpce-headless serve --root /srv/repoprompt-ce --socket /run/rpce-headless/rpce.sock
Restart=on-failure
RestartSec=2
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
ReadOnlyPaths=/srv/repoprompt-ce
ReadWritePaths=/run/rpce-headless /var/lib/rpce-headless /var/cache/rpce-headless

[Install]
WantedBy=multi-user.target
